.road-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.road-item.top-1,
.road-item.top-2,
.road-item.top-3 {
  background: #fffbf0;
  margin: 0 -30rpx;
  padding: 24rpx 30rpx;
  border-radius: 12rpx;
  border-bottom: none;
  margin-bottom: 8rpx;
}

.rank-badge {
  width: 60rpx;
  text-align: center;
  flex-shrink: 0;
}

.rank-medal {
  font-size: 40rpx;
}

.rank-number {
  font-size: 30rpx;
  font-weight: 600;
  color: #999;
}

.top-1 .rank-number,
.top-2 .rank-number,
.top-3 .rank-number {
  color: #e74c3c;
}

.road-info {
  flex: 1;
  margin-left: 20rpx;
}

.road-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  display: block;
}

.road-city {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.ticket-count {
  text-align: right;
  flex-shrink: 0;
}

.ticket-count .count {
  font-size: 36rpx;
  font-weight: 700;
  color: #e74c3c;
  display: block;
}

.ticket-count .label {
  font-size: 22rpx;
  color: #999;
}
