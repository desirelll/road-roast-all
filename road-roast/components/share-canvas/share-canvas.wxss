.share-canvas {
  position: fixed;
  inset: 0;
  z-index: 300;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.canvas-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.canvas {
  width: 600rpx;
  height: 900rpx;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.3);
}

.save-btn {
  margin-top: 30rpx;
  background: #e74c3c;
  color: #fff;
  padding: 20rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.close-hint {
  margin-top: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
}
