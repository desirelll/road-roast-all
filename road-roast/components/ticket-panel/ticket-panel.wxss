.overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.panel {
  width: 100%;
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  transition: margin-bottom 0.25s ease;
  animation: slideUp 0.25s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* 拖拽条 */
.drag-bar {
  display: flex;
  justify-content: center;
  padding: 10rpx 0 20rpx;
}

.drag-bar-inner {
  width: 60rpx;
  height: 6rpx;
  background: #ddd;
  border-radius: 3rpx;
}

/* 路段信息 */
.road-info {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.road-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  margin-top: 4rpx;
}

.road-detail {
  flex: 1;
}

.road-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.road-tickets {
  font-size: 26rpx;
  color: #e74c3c;
  margin-top: 6rpx;
  display: block;
}

/* 吐槽输入 */
.comment-area {
  position: relative;
  margin-bottom: 24rpx;
}

.comment-input {
  width: 100%;
  min-height: 120rpx;
  max-height: 200rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.char-count.full {
  color: #e74c3c;
}

/* 提交按钮 */
.post-btn {
  width: 100%;
  height: 88rpx;
  background: #e74c3c;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.post-btn.submitting {
  opacity: 0.75;
}

.post-btn[disabled] {
  opacity: 0.75;
}

.posting-inner {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* ========== 成功状态 ========== */
.success-view {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 10rpx;
}

/* 盖章动画 */
.stamp-container {
  margin-bottom: 24rpx;
}

.stamp {
  width: 140rpx;
  height: 140rpx;
  border: 8rpx solid #e74c3c;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: scale(0);
}

.stamp-pop {
  animation: stampBounce 0.55s ease forwards;
}

@keyframes stampBounce {
  0%   { transform: scale(0) rotate(-15deg); }
  50%  { transform: scale(1.35) rotate(-15deg); }
  100% { transform: scale(1) rotate(-15deg); }
}

.stamp-text {
  font-size: 80rpx;
  color: #e74c3c;
  font-weight: 900;
  transform: rotate(-15deg);
}

.result-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.result-road {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
  text-align: center;
}

.result-count {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 30rpx;
}

.result-count-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #e74c3c;
}

/* 分享按钮 */
.share-buttons {
  display: flex;
  gap: 20rpx;
  width: 100%;
  margin-bottom: 24rpx;
}

.share-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  gap: 8rpx;
}

.share-btn.chat {
  background: #27ae60;
  color: #fff;
}

.share-btn.timeline {
  background: #e74c3c;
  color: #fff;
}

.share-btn-icon {
  font-size: 32rpx;
}

.close-link {
  font-size: 28rpx;
  color: #999;
  padding: 10rpx;
}
