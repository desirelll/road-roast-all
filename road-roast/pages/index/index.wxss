.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  position: relative;
}

/* ========== 授权弹窗 ========== */
.auth-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-panel {
  width: 85%;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.auth-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.auth-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.auth-avatar-wrap {
  margin-bottom: 30rpx;
}

.auth-avatar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: none;
  border: none;
  padding: 0;
  line-height: normal;
}

.auth-avatar-btn::after {
  display: none;
}

.auth-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #f0f0f0;
  margin-bottom: 12rpx;
}

.auth-avatar-hint {
  font-size: 24rpx;
  color: #e74c3c;
}

.auth-nickname-wrap {
  width: 100%;
  margin-bottom: 40rpx;
}

.auth-nickname-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  text-align: center;
}

.auth-submit-btn {
  width: 100%;
  height: 88rpx;
  background: #e74c3c;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
}

.auth-submit-btn[disabled] {
  background: #ccc;
  color: #999;
}

/* 搜索栏 */
.search-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 16rpx 30rpx;
  padding-top: calc(16rpx + env(safe-area-inset-top));
  background: #fff;
  z-index: 20;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  position: absolute;
  left: 50rpx;
  font-size: 32rpx;
  z-index: 1;
}

/* 地图骨架屏 */
.map-skeleton {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
}

.skeleton-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  animation: skeletonPulse 1.5s ease-in-out infinite;
}

.skeleton-text {
  font-size: 28rpx;
  color: #999;
  animation: skeletonPulse 1.5s ease-in-out infinite;
}

@keyframes skeletonPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 60rpx 0 80rpx;
  font-size: 28rpx;
}

.search-clear {
  position: absolute;
  right: 40rpx;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
  background: #ddd;
  border-radius: 50%;
}

/* 搜索结果 */
.search-results {
  position: absolute;
  top: 104rpx;
  left: 0;
  right: 0;
  background: #fff;
  z-index: 15;
  max-height: 500rpx;
  overflow-y: auto;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border-radius: 0 0 12rpx 12rpx;
}

.search-item {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-item-left {
  flex: 1;
}

.search-item-name {
  font-size: 30rpx;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.search-item-addr {
  font-size: 24rpx;
  color: #999;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-item-right {
  margin-left: 16rpx;
}

.search-item-tickets {
  font-size: 26rpx;
  color: #e74c3c;
  font-weight: 500;
}

.search-item-badge {
  font-size: 22rpx;
  color: #27ae60;
  background: #eafaf1;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

/* 附近路段推荐 */
.nearby-section {
  background: #fff;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.nearby-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  padding: 0 30rpx;
  margin-bottom: 16rpx;
}

.nearby-list {
  white-space: nowrap;
  padding: 0 30rpx;
}

.nearby-item {
  display: inline-block;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin-right: 16rpx;
  min-width: 180rpx;
}

.nearby-name {
  font-size: 26rpx;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nearby-count {
  font-size: 22rpx;
  color: #e74c3c;
}

.no-result {
  padding: 40rpx 30rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 地图 */
.map-container {
  flex: 1;
  width: 100%;
  position: relative;
}

.map-container map {
  width: 100%;
  height: 100%;
}

.locate-btn {
  position: absolute;
  right: 20rpx;
  bottom: 220rpx;
  width: 72rpx;
  height: 72rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.12);
  font-size: 36rpx;
  color: #333;
}

.location-hint {
  position: absolute;
  left: 30rpx;
  right: 118rpx;
  bottom: 226rpx;
  min-height: 60rpx;
  padding: 0 22rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  color: #666;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 定位降级 */
.map-placeholder {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
}

.map-placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.map-placeholder-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.map-placeholder-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.retry-btn {
  background: #e74c3c;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  border: none;
}

/* ========== 成功弹窗 ========== */
.result-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}

.result-panel {
  width: 100%;
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 40rpx 30rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: rSlideUp 0.3s ease;
}

@keyframes rSlideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.r-stamp {
  width: 140rpx;
  height: 140rpx;
  border: 8rpx solid #e74c3c;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: scale(0);
}

.r-stamp-pop {
  animation: rStampBounce 0.55s ease forwards;
}

@keyframes rStampBounce {
  0%   { transform: scale(0) rotate(-15deg); }
  50%  { transform: scale(1.35) rotate(-15deg); }
  100% { transform: scale(1) rotate(-15deg); }
}

.r-stamp-text {
  font-size: 80rpx;
  color: #e74c3c;
  font-weight: 900;
  transform: rotate(-15deg);
}

.r-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-top: 24rpx;
}

.r-road {
  font-size: 30rpx;
  color: #666;
  margin-top: 12rpx;
}

.r-count {
  font-size: 28rpx;
  color: #333;
  margin-top: 12rpx;
}

.r-count-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #e74c3c;
}

.r-btns {
  display: flex;
  gap: 20rpx;
  width: 100%;
  margin-top: 30rpx;
}

.r-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  gap: 6rpx;
}

.r-btn.chat {
  background: #27ae60;
  color: #fff;
}

.r-btn.moments {
  background: #e74c3c;
  color: #fff;
}

.r-close {
  font-size: 28rpx;
  color: #999;
  margin-top: 24rpx;
}
