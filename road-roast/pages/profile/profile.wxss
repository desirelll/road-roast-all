.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.user-header {
  display: flex;
  align-items: center;
  padding: 50rpx 30rpx 40rpx;
  background: linear-gradient(135deg, #e74c3c, #ff6b5b);
  color: #fff;
}

.avatar-wrap {
  position: relative;
  width: 110rpx;
  height: 110rpx;
  flex-shrink: 0;
}

.avatar-btn {
  position: absolute;
  top: 0;
  left: 0;
  width: 110rpx;
  height: 110rpx;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  opacity: 0;
}

.avatar-btn::after {
  border: none;
}

.user-avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  display: block;
}

.user-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.nickname-input {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  background: none;
  border: none;
  padding: 0;
  height: 44rpx;
  margin-bottom: 10rpx;
}

.user-stats {
  font-size: 28rpx;
  opacity: 0.9;
}

.user-stats .count {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffe066;
}

.section {
  margin-top: 20rpx;
  background: #fff;
}

.section-title {
  padding: 24rpx 30rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
}

.ticket-item {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.ticket-date {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.ticket-road {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.ticket-comment {
  font-size: 26rpx;
  color: #666;
  font-style: italic;
}

.empty-tickets {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.go-ticket {
  display: inline-block;
  margin-top: 20rpx;
  color: #e74c3c;
  font-weight: 500;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}
