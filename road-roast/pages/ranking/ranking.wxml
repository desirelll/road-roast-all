<view class="container">
  <!-- 类型切换 -->
  <view class="type-tabs">
    <view
      class="type-tab {{tabType === 'road' ? 'active' : ''}}"
      bindtap="onTabChange"
      data-tab="road"
    >
      路段排行
    </view>
    <view
      class="type-tab {{tabType === 'user' ? 'active' : ''}}"
      bindtap="onTabChange"
      data-tab="user"
    >
      达人排行
    </view>
  </view>

  <!-- 路段排行筛选 -->
  <view class="filter-bar" wx:if="{{tabType === 'road'}}">
    <view class="scope-tabs">
      <view
        class="scope-tab {{scope === 'national' ? 'active' : ''}}"
        bindtap="onScopeChange"
        data-scope="national"
      >
        全国榜
      </view>
      <view
        class="scope-tab {{scope === 'city' ? 'active' : ''}}"
        bindtap="onScopeChange"
        data-scope="city"
      >
        我的城市
      </view>
    </view>

    <!-- 时间筛选 -->
    <view class="period-tabs">
      <view
        class="period-tab {{period === 'week' ? 'active' : ''}}"
        bindtap="onPeriodChange"
        data-period="week"
      >
        本周
      </view>
      <view
        class="period-tab {{period === 'month' ? 'active' : ''}}"
        bindtap="onPeriodChange"
        data-period="month"
      >
        本月
      </view>
      <view
        class="period-tab {{period === 'year' ? 'active' : ''}}"
        bindtap="onPeriodChange"
        data-period="year"
      >
        本年
      </view>
      <view
        class="period-tab {{period === 'all' ? 'active' : ''}}"
        bindtap="onPeriodChange"
        data-period="all"
      >
        总榜
      </view>
    </view>
  </view>

  <!-- 我的排名（用户排行） -->
  <view class="my-rank-bar" wx:if="{{tabType === 'user' && myRank}}">
    <text>我的排名：第 {{myRank}} 名</text>
  </view>

  <!-- 路段排行列表 -->
  <view class="ranking-list" wx:if="{{tabType === 'road' && rankings.length > 0}}">
    <view
      wx:for="{{rankings}}"
      wx:key="roadId"
      bindtap="onRoadTap"
      data-road-id="{{item.roadId}}"
    >
      <road-item rank="{{index + 1}}" road="{{item}}" />
    </view>
  </view>

  <!-- 用户排行列表 -->
  <view class="ranking-list" wx:if="{{tabType === 'user' && userRankings.length > 0}}">
    <view class="user-rank-item" wx:for="{{userRankings}}" wx:key="rank">
      <text class="user-rank-num {{item.rank <= 3 ? 'top3' : ''}}">{{item.rank}}</text>
      <image class="user-rank-avatar" src="{{item.avatar || '/images/default-avatar.png'}}" mode="aspectFill" />
      <text class="user-rank-name">{{item.nickname}}</text>
      <text class="user-rank-count">{{item.totalTickets}} 张</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && ((tabType === 'road' && rankings.length === 0) || (tabType === 'user' && userRankings.length === 0))}}">
    <text class="empty-text">还没有数据，快去贴罚单吧</text>
    <navigator url="/pages/index/index" open-type="switchTab" class="empty-btn">去贴罚单</navigator>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
