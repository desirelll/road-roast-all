.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* 类型切换 */
.type-tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 30rpx;
  gap: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.type-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 30rpx;
  color: #666;
  border-radius: 8rpx;
  background: #f5f5f5;
}

.type-tab.active {
  background: #e74c3c;
  color: #fff;
}

/* 我的排名 */
.my-rank-bar {
  background: #fde8e8;
  padding: 16rpx 30rpx;
  font-size: 26rpx;
  color: #e74c3c;
  font-weight: 500;
}

/* 用户排行列表 */
.user-rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.user-rank-num {
  width: 60rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #999;
  text-align: center;
}

.user-rank-num.top3 {
  color: #e74c3c;
}

.user-rank-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin: 0 20rpx;
  background: #f0f0f0;
}

.user-rank-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-rank-count {
  font-size: 26rpx;
  color: #e74c3c;
  font-weight: 500;
}

.filter-bar {
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.scope-tabs {
  display: flex;
  padding: 20rpx 30rpx;
  gap: 20rpx;
}

.scope-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 30rpx;
  color: #666;
  border-radius: 8rpx;
  background: #f5f5f5;
}

.scope-tab.active {
  background: #e74c3c;
  color: #fff;
}

.period-tabs {
  display: flex;
  padding: 0 30rpx 20rpx;
  gap: 16rpx;
}

.period-tab {
  flex: 1;
  text-align: center;
  padding: 10rpx 0;
  font-size: 26rpx;
  color: #999;
  border-radius: 6rpx;
  background: #f5f5f5;
}

.period-tab.active {
  background: #fde8e8;
  color: #e74c3c;
  font-weight: 500;
}

.ranking-list {
  padding: 20rpx 30rpx;
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.empty-btn {
  background: #e74c3c;
  color: #fff;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}
