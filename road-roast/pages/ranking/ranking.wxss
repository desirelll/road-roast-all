.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.filter-bar {
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.scope-tabs {
  display: flex;
  padding: 20rpx 30rpx;
  gap: 20rpx;
}

.scope-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 30rpx;
  color: #666;
  border-radius: 8rpx;
  background: #f5f5f5;
}

.scope-tab.active {
  background: #e74c3c;
  color: #fff;
}

.period-tabs {
  display: flex;
  padding: 0 30rpx 20rpx;
  gap: 16rpx;
}

.period-tab {
  flex: 1;
  text-align: center;
  padding: 10rpx 0;
  font-size: 26rpx;
  color: #999;
  border-radius: 6rpx;
  background: #f5f5f5;
}

.period-tab.active {
  background: #fde8e8;
  color: #e74c3c;
  font-weight: 500;
}

.ranking-list {
  padding: 20rpx 30rpx;
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.empty-btn {
  background: #e74c3c;
  color: #fff;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}
